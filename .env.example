# .env.example
# Salin file ini menjadi .env lalu ubah nilainya yang sesuai di mesin tujuan

DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5432/pos_cerdas_db
SECRET_KEY=ganti_dengan_kunci_rahasia_anda_yang_sangat_panjang_sekali!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- App ----
APP_NAME=InsightSphere
FRONTEND_URL=http://localhost:3000

# ---- Email (SMTP) ----
# Kosongkan SMTP_HOST utk MODE CONSOLE (email akan di-log ke stdout, tidak terkirim).
# Untuk Gmail: gunakan App Password (https://myaccount.google.com/apppasswords).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_USE_TLS=true

# ---- Token expiry (jam) ----
INVITE_TOKEN_EXPIRE_HOURS=168
RESET_TOKEN_EXPIRE_HOURS=1